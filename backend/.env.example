# 复制本文件为 .env 后按需修改。.env 已被 .gitignore 忽略，不会进 GitHub。

# JWT 签名密钥（务必改成你自己的随机串）。生成方法：
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-long-random-string

# 登录有效期（天）
ACCESS_TOKEN_EXPIRE_DAYS=7

# 允许访问的前端来源，逗号分隔。本地开发用 *；上云后改成你的域名，如：
#   CORS_ORIGINS=https://yourdomain.com
CORS_ORIGINS=*

# 是否开放自助注册（true/false）
ALLOW_REGISTRATION=true

# 运行环境：development（默认）或 production
# production 时 SECRET_KEY / APP_BASE_URL 为必填，缺失则启动失败
ENV=development

# 应用对外 URL（邮件中的链接用此值，生产环境必填）
APP_BASE_URL=http://localhost:5173

# ---------- 邮件配置 ----------
# EMAIL_ENABLED=false 时，验证链接打印到控制台，方便本地开发
EMAIL_ENABLED=false
EMAIL_FROM=noreply@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# SMTP_TLS=false → STARTTLS（端口 587，Gmail/163/QQ 推荐）
# SMTP_TLS=true  → SMTP_SSL（端口 465）
SMTP_TLS=false

# ---------- BYOK（用户自带 API Key）加密配置 ----------
# API Key 加密密钥（Fernet 格式，生产环境必填）。
# 生成命令：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 警告：更换此密钥后，已保存的用户 API Key 将无法解密，需让用户重新配置。
APP_ENCRYPTION_KEY=

# 是否允许在用户未配置 API Key 时回退到系统全局 Key（默认 false）。
# false：用户必须在个人资料 → AI 设置中配置自己的 Key 才能使用 AI 投研。
# true：用户没有 Key 时可使用下面的系统全局 Key（站长自用 / 测试模式）。
ALLOW_SYSTEM_AI_FALLBACK=false

# ---------- 系统全局 AI Key（站长自用或 ALLOW_SYSTEM_AI_FALLBACK=true 时有效）----------
# On Fly.io, configure these with `fly secrets set`, not by uploading this file.
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=
GLM_API_KEY=
ANTHROPIC_API_KEY=

# Refresh cached USD/CNY after this many seconds. Default: 6 hours.
FX_REFRESH_INTERVAL_SECONDS=21600
